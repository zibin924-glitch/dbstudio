# DBStudio 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# 数据库密码加密密钥（必填，64位十六进制字符串）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
DBSTUDIO_ENCRYPTION_KEY=YOUR_64_CHAR_HEX_ENCRYPTION_KEY_HERE

# 调试模式（true/false）
DBSTUDIO_DEBUG=false

# API Key 认证（留空表示禁用 API Key 认证）
# 设置后所有 /api/ 端点需要在请求头中包含 X-API-Key
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
DBSTUDIO_API_KEY=

# 数据库连接 URL（默认使用 SQLite）
# DBSTUDIO_DATABASE_URL=sqlite+aiosqlite:///./dbstudio.db

# CORS 允许的来源（逗号分隔，生产环境请配置具体域名）
# DBSTUDIO_CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# 查询超时时间（秒）
# DBSTUDIO_QUERY_TIMEOUT=30

# 日志级别
# DBSTUDIO_LOG_LEVEL=INFO
